# ─── AI Model ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ─── Bybit (CEX) ──────────────────────────────────────────────────────────────
BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_TESTNET=true          # set to false for live trading

# ─── EVM Wallet (shared by Hyperliquid, Uniswap, GMX) ────────────────────────
WALLET_PRIVATE_KEY=0x...    # NEVER commit this
WALLET_ADDRESS=0x...

# ─── RPC URLs ─────────────────────────────────────────────────────────────────
ETHEREUM_RPC_URL=https://mainnet.infura.io/v3/YOUR_KEY
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc

# ─── Hyperliquid ──────────────────────────────────────────────────────────────
HL_TESTNET=true

# ─── dYdX v4 ─────────────────────────────────────────────────────────────────
DYDX_MNEMONIC=word1 word2 word3 ... word24
DYDX_TESTNET=true

# ─── Polymarket ───────────────────────────────────────────────────────────────
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_PASSPHRASE=

# ─── Notifications ────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ─── Strategy ────────────────────────────────────────────────────────────────
MAX_POSITION_USD=100
DAILY_LOSS_LIMIT=8
REQUIRE_APPROVAL=false

# ─── File paths (optional overrides) ─────────────────────────────────────────
TRADE_LOG_PATH=./data/live-trades.json
PARAMS_PATH=./data/params.json
HISTORY_PATH=./data/params-history.json
